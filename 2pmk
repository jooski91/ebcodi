<script>
// ===== DEFAULT DATA =====
const DEFAULT_MENUS = [
  {id:1,name:"치킨",emoji:"🍗",desc:"황금빛 바삭한 치킨! 야식의 영원한 클래식.",tags:["국민야식","배달가능","맥주안주"],mood:"meat",temp:"hot",enabled:true,custom:false},
  {id:2,name:"라면",emoji:"🍜",desc:"새벽 감성 한 방울, 라면 한 그릇.",tags:["혼자야식","저렴","빠름"],mood:"simple",temp:"hot",enabled:true,custom:false},
  {id:3,name:"피자",emoji:"🍕",desc:"치즈가 쭈욱 늘어나는 피자!",tags:["여럿이","배달가능","든든함"],mood:"sweet",temp:"hot",enabled:true,custom:false},
  {id:4,name:"떡볶이",emoji:"🌶️",desc:"매콤달콤한 떡볶이! 스트레스 날아가는 느낌.",tags:["매운맛","저렴","포장마차"],mood:"spicy",temp:"hot",enabled:true,custom:false},
  {id:5,name:"족발/보쌈",emoji:"🥩",desc:"쫄깃한 족발과 새콤한 겉절이의 조화.",tags:["여럿이","든든함","안주용"],mood:"meat",temp:"hot",enabled:true,custom:false},
  {id:6,name:"아이스크림",emoji:"🍦",desc:"달달하고 시원한 아이스크림!",tags:["가볍게","달달함","편의점픽"],mood:"sweet",temp:"cold",enabled:true,custom:false},
  {id:7,name:"곱창/막창",emoji:"🍢",desc:"불 위에서 지글지글~ 야식 고수들의 선택.",tags:["특별한야식","안주용","불맛"],mood:"meat",temp:"hot",enabled:true,custom:false},
  {id:8,name:"편의점 도시락",emoji:"🍱",desc:"가성비 최강 편의점 도시락!",tags:["혼자야식","빠름","가성비"],mood:"simple",temp:"any",enabled:true,custom:false},
  {id:9,name:"냉면",emoji:"🫙",desc:"시원하고 새콤한 냉면 한 그릇.",tags:["시원함","가볍게","개운함"],mood:"simple",temp:"cold",enabled:true,custom:false},
  {id:10,name:"삼겹살",emoji:"🥓",desc:"숯불에 구워먹는 삼겹살!",tags:["여럿이","고기파티","소주필수"],mood:"meat",temp:"hot",enabled:true,custom:false},
  {id:11,name:"떡순이/야식세트",emoji:"🛒",desc:"떡볶이+순대+오뎅 콤보!",tags:["매운맛","세트구성","저렴"],mood:"spicy",temp:"hot",enabled:true,custom:false},
  {id:12,name:"마라탕",emoji:"🫕",desc:"얼얼하고 중독적인 마라탕!",tags:["매운맛","얼얼함","중독주의"],mood:"spicy",temp:"hot",enabled:true,custom:false},
];
const DEFAULT_SETTINGS = {showRunnerUp:false,showRandomBtn:true,excludeDisabled:true,budgetPref:"any"};

let menus=[], settings={}, history=[], isDirty=false, nextId=100;
let pendingEat=null;

function loadState() {
  try {
    const sm=localStorage.getItem("yasik_menus");
    const ss=localStorage.getItem("yasik_settings");
    const sh=localStorage.getItem("yasik_history");
    menus=sm?JSON.parse(sm):JSON.parse(JSON.stringify(DEFAULT_MENUS));
    settings=ss?JSON.parse(ss):{...DEFAULT_SETTINGS};
    history=sh?JSON.parse(sh):[];
    nextId=Math.max(...menus.map(m=>m.id),99)+1;
  } catch(e) {
    menus=JSON.parse(JSON.stringify(DEFAULT_MENUS));
    settings={...DEFAULT_SETTINGS};
    history=[];
  }
}
function saveState() {
  localStorage.setItem("yasik_menus",JSON.stringify(menus));
  localStorage.setItem("yasik_settings",JSON.stringify(settings));
  localStorage.setItem("yasik_history",JSON.stringify(history));
}

// NAV
function goPage(name,btn) {
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('page-'+name).classList.add('active');
  (btn||document.getElementById('nav-'+name)).classList.add('active');
  if(name==='settings') renderSettings();
  if(name==='history') renderHistory();
}

// ===== EAT MODAL =====
let currentResultMenu = null;
function openEatModal() {
  if(!currentResultMenu) return;
  document.getElementById('modal-menu-title').textContent = currentResultMenu.emoji+' '+currentResultMenu.name;
  document.getElementById('modal-note').value = '';
  document.getElementById('note-modal').classList.add('open');
}
function closeModal() { document.getElementById('note-modal').classList.remove('open'); }
function confirmEat() {
  const note = document.getElementById('modal-note').value.trim();
  const now = new Date();
  const entry = {
    id: Date.now(),
    menuId: currentResultMenu.id,
    name: currentResultMenu.name,
    emoji: currentResultMenu.emoji,
    note: note,
    ts: now.getTime(),
    dateStr: formatDate(now),
    timeStr: formatTime(now),
  };
  history.unshift(entry);
  saveState();
  closeModal();
  // update button
  const eatBtn = document.getElementById('eat-btn');
  eatBtn.textContent = '✓ 냠냠 기록됐어요!';
  eatBtn.classList.add('eaten');
  eatBtn.disabled = true;
  document.getElementById('tip-text').textContent = '기록 탭에서 야식 히스토리를 확인해봐요 📅';
  showToast('야식 기록 완료! '+currentResultMenu.emoji);
}
function formatDate(d) {
  const days=['일','월','화','수','목','금','토'];
  return `${d.getFullYear()}년 ${d.getMonth()+1}월 ${d.getDate()}일 (${days[d.getDay()]})`;
}
function formatTime(d) {
  const h=d.getHours(), m=d.getMinutes();
  const ampm=h<12?'오전':'오후';
  const hh=h%12||12;
  return `${ampm} ${hh}:${String(m).padStart(2,'0')}`;
}
function formatMonthKey(ts) {
  const d=new Date(ts);
  return `${d.getFullYear()}년 ${d.getMonth()+1}월`;
}

// ===== HISTORY RENDER =====
function renderHistory() {
  const body = document.getElementById('history-body');
  const statsEl = document.getElementById('history-stats');

  if(history.length===0) {
    statsEl.innerHTML='';
    body.innerHTML=`<div class="history-empty">
      <span class="history-empty-emoji">🌙</span>
      <p class="history-empty-text">아직 야식 기록이 없어요</p>
      <p class="history-empty-hint">추천 받은 뒤 "이걸로 먹을래!" 버튼을 눌러보세요</p>
    </div>`;
    return;
  }

  // stats
  const total = history.length;
  const favMap={};
  history.forEach(e=>{ favMap[e.name]=(favMap[e.name]||0)+1; });
  const favName = Object.entries(favMap).sort((a,b)=>b[1]-a[1])[0];
  statsEl.innerHTML=`
    <div class="hstat"><p class="hstat-num">${total}</p><p class="hstat-label">총 야식</p></div>
    <div class="hstat"><p class="hstat-num">${Object.keys(favMap).length}</p><p class="hstat-label">종류</p></div>
    ${favName?`<div class="hstat"><p class="hstat-num">${favName[0].length>4?favName[0].slice(0,4)+'..':favName[0]}</p><p class="hstat-label">최애메뉴</p></div>`:''}`;

  // favorites
  const favSorted = Object.entries(favMap).sort((a,b)=>b[1]-a[1]).slice(0,6);
  const favMenu = menus.find(m=>m.name===favSorted[0]?.[0]);
  let favHTML = `<div class="fav-section"><p class="fav-title">⭐ 자주 먹은 메뉴</p><div class="fav-list">`;
  favSorted.forEach(([name,cnt],i)=>{
    const m=menus.find(m=>m.name===name);
    favHTML+=`<div class="fav-chip ${i===0?'rank1':''}">
      <span class="fav-chip-emoji">${m?m.emoji:'🍽️'}</span>
      <span class="fav-chip-name">${name}</span>
      <span class="fav-chip-cnt">${cnt}회</span>
    </div>`;
  });
  favHTML+=`</div></div>`;

  // heat chart (last 60 days)
  const heatMap={};
  history.forEach(e=>{ const d=new Date(e.ts); const k=`${d.getFullYear()}-${d.getMonth()}-${d.getDate()}`; heatMap[k]=(heatMap[k]||0)+1; });
  let heatHTML=`<div class="heat-section"><p class="heat-title">🔥 최근 60일 야식 빈도</p><div class="heat-chart">`;
  const now=new Date();
  for(let i=59;i>=0;i--) {
    const d=new Date(now); d.setDate(d.getDate()-i);
    const k=`${d.getFullYear()}-${d.getMonth()}-${d.getDate()}`;
    const cnt=heatMap[k]||0;
    const cls=cnt===0?'':cnt===1?'h1':cnt===2?'h2':'h3';
    heatHTML+=`<div class="heat-cell ${cls}" title="${d.getMonth()+1}/${d.getDate()} · ${cnt}회"></div>`;
  }
  heatHTML+=`</div></div>`;

  // group by month then day
  const monthGroups={};
  history.forEach(e=>{
    const mk=formatMonthKey(e.ts);
    if(!monthGroups[mk]) monthGroups[mk]=[];
    monthGroups[mk].push(e);
  });

  let tlHTML='';
  Object.entries(monthGroups).forEach(([month,entries])=>{
    tlHTML+=`<div class="tl-month-header"><span class="tl-month-label">${month}</span><div class="tl-month-line"></div></div>`;
    const dayGroups={};
    entries.forEach(e=>{
      if(!dayGroups[e.dateStr]) dayGroups[e.dateStr]=[];
      dayGroups[e.dateStr].push(e);
    });
    Object.entries(dayGroups).forEach(([day,dayEntries])=>{
      tlHTML+=`<div class="tl-day-group">
        <div class="tl-day-header">
          <div class="tl-day-dot"></div>
          <span class="tl-day-label">${day}</span>
          <span class="tl-day-count">${dayEntries.length}개</span>
          <div class="tl-connector"></div>
        </div>
        <div class="tl-entries">`;
      dayEntries.forEach(e=>{
        tlHTML+=`<div class="tl-entry" id="entry-${e.id}">
          <div class="tl-entry-emoji">${e.emoji}</div>
          <div class="tl-entry-body">
            <p class="tl-entry-name">${e.name}</p>
            <p class="tl-entry-time">${e.timeStr}</p>
            ${e.note?`<p class="tl-entry-note">"${e.note}"</p>`:''}
          </div>
          <div class="tl-entry-right">
            <button class="tl-del-btn" onclick="deleteEntry(${e.id})" title="삭제">✕</button>
          </div>
        </div>`;
      });
      tlHTML+=`</div></div>`;
    });
  });

  body.innerHTML = heatHTML + favHTML + `<div class="timeline">${tlHTML}</div>`;
}

function deleteEntry(id) {
  history=history.filter(e=>e.id!==id);
  saveState();
  renderHistory();
}

// ===== SETTINGS =====
function renderSettings() {
  document.getElementById('opt-runner-up').checked=settings.showRunnerUp;
  document.getElementById('opt-random-btn').checked=settings.showRandomBtn;
  document.getElementById('opt-exclude-disabled').checked=settings.excludeDisabled;
  document.querySelectorAll('#budget-pref .mood-opt').forEach(el=>el.classList.toggle('selected',el.dataset.val===settings.budgetPref));
  renderMenuList(); updateMenuCount();
}
function renderMenuList() {
  document.getElementById('menu-list').innerHTML=menus.map(m=>`
    <div class="menu-item ${m.enabled?'':'disabled'}">
      <div class="menu-emoji-badge">${m.emoji}</div>
      <div class="menu-info">
        <p class="menu-item-name">${m.name}</p>
        <p class="menu-item-tags">${m.tags.map(t=>'#'+t).join(' ')}</p>
      </div>
      <div class="menu-actions">
        <button class="menu-toggle-btn ${m.enabled?'on':''}" onclick="toggleMenu(${m.id})">${m.enabled?'켜짐':'꺼짐'}</button>
        ${m.custom?`<button class="menu-delete-btn" onclick="deleteMenu(${m.id})">✕</button>`:''}
      </div>
    </div>`).join('');
}
function updateMenuCount() {
  const a=menus.filter(m=>m.enabled).length;
  document.getElementById('menu-count-badge').textContent=`${a}/${menus.length}개 활성`;
}
function selectMood(gid,el) {
  document.querySelectorAll(`#${gid} .mood-opt`).forEach(e=>e.classList.remove('selected'));
  el.classList.add('selected');
  if(gid==='budget-pref') settings.budgetPref=el.dataset.val;
  markDirty();
}
function toggleMenu(id) {
  const m=menus.find(m=>m.id===id);
  if(m){m.enabled=!m.enabled;renderMenuList();updateMenuCount();markDirty();}
}
function deleteMenu(id) {
  if(!confirm('삭제할까요?')) return;
  menus=menus.filter(m=>m.id!==id);
  renderMenuList();updateMenuCount();markDirty();
}
function addMenu() {
  const emoji=document.getElementById('new-emoji').value.trim()||'🍽️';
  const name=document.getElementById('new-name').value.trim();
  const desc=document.getElementById('new-desc').value.trim();
  const tagsRaw=document.getElementById('new-tags').value.trim();
  const mood=document.getElementById('new-mood').value;
  const temp=document.getElementById('new-temp').value;
  if(!name){showToast('메뉴 이름을 입력해주세요!');return;}
  const tags=tagsRaw?tagsRaw.split(',').map(t=>t.trim()).filter(Boolean):[name];
  menus.push({id:nextId++,name,emoji,desc:desc||`${name}! 새로 추가된 야식 메뉴.`,tags,mood,temp,enabled:true,custom:true});
  ['new-emoji','new-name','new-desc','new-tags'].forEach(id=>document.getElementById(id).value='');
  document.getElementById('new-mood').value='any';
  document.getElementById('new-temp').value='any';
  renderMenuList();updateMenuCount();markDirty();
  showToast(`'${name}' 추가됐어요! 🎉`);
}
function markDirty() {
  settings.showRunnerUp=document.getElementById('opt-runner-up').checked;
  settings.showRandomBtn=document.getElementById('opt-random-btn').checked;
  settings.excludeDisabled=document.getElementById('opt-exclude-disabled').checked;
  isDirty=true;
  document.getElementById('save-bar').classList.add('visible');
}
function saveSettings() {
  saveState(); isDirty=false;
  document.getElementById('save-bar').classList.remove('visible');
  const rb=document.getElementById('random-btn');
  if(rb) rb.style.display=settings.showRandomBtn?'block':'none';
  showToast('설정 저장 완료 ✓');
}
function showToast(msg) {
  const t=document.getElementById('toast');
  t.textContent=msg;t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),2200);
}

// ===== QUIZ =====
const questions=[
  {emoji:"😤",text:"지금 당신의 배고픔 단계는?",options:[{emoji:"😐",label:"좀 출출해",val:"light"},{emoji:"😤",label:"꽤 배고파",val:"medium"},{emoji:"🤤",label:"엄청 배고파",val:"heavy"},{emoji:"💀",label:"죽을 것 같아",val:"starving"}]},
  {emoji:"🌡️",text:"따뜻한 거 vs 차가운 거?",options:[{emoji:"🔥",label:"뜨끈한 게 좋아",val:"hot"},{emoji:"❄️",label:"차가운 게 좋아",val:"cold"},{emoji:"🤷",label:"상관없어",val:"any_temp"},{emoji:"💦",label:"시원하고 든든하게",val:"cold_heavy"}]},
  {emoji:"💸",text:"오늘 야식 예산은?",options:[{emoji:"🪙",label:"1만원 이하",val:"cheap"},{emoji:"💵",label:"1~2만원",val:"mid"},{emoji:"💰",label:"2만원 이상",val:"expensive"},{emoji:"😵",label:"배달비도 아까워",val:"free"}]},
  {emoji:"👥",text:"혼자야 아니면 같이야?",options:[{emoji:"🧍",label:"혼자 먹을 거야",val:"solo"},{emoji:"👫",label:"둘이서",val:"two"},{emoji:"👨‍👩‍👧",label:"셋 이상",val:"group"},{emoji:"🤔",label:"아직 모르겠어",val:"any_size"}]},
  {emoji:"🍽️",text:"오늘 느낌은?",options:[{emoji:"🌶️",label:"매운 게 당겨",val:"spicy"},{emoji:"🧀",label:"달달한 게 좋아",val:"sweet"},{emoji:"🥩",label:"든든하게 고기!",val:"meat"},{emoji:"🥡",label:"간단하게 뭔가",val:"simple"}]},
];
let answers={}, currentQ=0;

function getActiveMenus() { return settings.excludeDisabled?menus.filter(m=>m.enabled):menus; }
function scoreMenu(m,a) {
  let s=0;
  if(a.mood&&m.mood!=='any') s+=(m.mood===a.mood?4:0);
  if(a.temp){
    if(m.temp==='hot'&&a.temp==='hot') s+=3;
    if(m.temp==='cold'&&(a.temp==='cold'||a.temp==='cold_heavy')) s+=3;
    if(m.temp==='any') s+=1;
  }
  if(a.group&&['여럿이','고기파티'].some(t=>m.tags.includes(t))) s+=3;
  if(a.solo&&['혼자야식','1인분','가성비'].some(t=>m.tags.includes(t))) s+=2;
  if(a.hungry>=2&&['든든함','고열량','국민야식'].some(t=>m.tags.includes(t))) s+=2;
  if(a.hungry===0&&['가볍게','저렴'].some(t=>m.tags.includes(t))) s+=2;
  s+=Math.random()*.5;
  return s;
}
function buildProgress() {
  document.getElementById("progress-bar").innerHTML=questions.map((_,i)=>
    `<div class="progress-dot ${i<currentQ?"done":i===currentQ?"active":""}"></div>`).join("");
}
function showQuestion(idx) {
  const q=questions[idx];
  document.getElementById("question-area").innerHTML=`<p class="q-label">질문 ${idx+1} / ${questions.length}</p><span class="q-emoji">${q.emoji}</span><p class="q-text">${q.text}</p>`;
  document.getElementById("options-area").innerHTML=q.options.map(o=>`<button class="opt-btn" onclick="answer('${o.val}')"><span class="opt-emoji">${o.emoji}</span>${o.label}</button>`).join("");
  buildProgress();
}
function answer(val) {
  if(currentQ===0){const m={light:0,medium:1,heavy:2,starving:3};answers.hungry=m[val]??1;}
  else if(currentQ===1) answers.temp=val;
  else if(currentQ===2) answers.budget=val;
  else if(currentQ===3){answers.solo=val==="solo";answers.two=val==="two";answers.group=val==="group";}
  else if(currentQ===4) answers.mood=val;
  currentQ++;
  if(currentQ<questions.length) showQuestion(currentQ);
  else showResult();
}
function showResult() {
  const active=getActiveMenus();
  if(active.length===0){alert('활성화된 메뉴가 없어요!');restart();return;}
  const scored=active.map(m=>({...m,s:scoreMenu(m,answers)})).sort((a,b)=>b.s-a.s);
  const top=scored[0];
  currentResultMenu=top;
  document.getElementById("quiz-section").style.display="none";
  document.getElementById("result-area").style.display="block";
  document.getElementById("res-emoji").textContent=top.emoji;
  document.getElementById("res-name").textContent=top.name;
  document.getElementById("res-desc").textContent=top.desc;
  document.getElementById("res-tags").innerHTML=top.tags.map(t=>`<span class="tag">#${t}</span>`).join("");
  const ru=document.getElementById('res-runner-up');
  if(settings.showRunnerUp&&scored.length>1){
    ru.innerHTML=`<p class="runner-label">이런 것도 어때요?</p><div class="runner-items">${scored.slice(1,3).map(r=>`<span class="runner-item">${r.emoji} ${r.name}</span>`).join('')}</div>`;
  } else ru.innerHTML='';
  const eb=document.getElementById('eat-btn');
  eb.textContent='🍽️ 이걸로 먹을래!';
  eb.classList.remove('eaten');
  eb.disabled=false;
  document.getElementById('tip-text').textContent='맛있게 드세요 🌙';
}
function restart() {
  currentQ=0;answers={};currentResultMenu=null;
  document.getElementById("result-area").style.display="none";
  document.getElementById("quiz-section").style.display="block";
  document.getElementById("roulette-wrap").style.display="none";
  document.getElementById('random-btn').style.display=settings.showRandomBtn?'block':'none';
  showQuestion(0);
}
let rouletteInterval=null;
function randomPick() {
  const active=getActiveMenus();
  if(active.length===0){showToast('활성화된 메뉴가 없어요!');return;}
  const wrap=document.getElementById("roulette-wrap");
  wrap.style.display="block";
  const se=document.getElementById("spin-emoji"),sn=document.getElementById("spin-name");
  se.style.animation="spin .3s linear infinite";sn.textContent="";
  let count=0;const maxCount=22;
  if(rouletteInterval) clearInterval(rouletteInterval);
  rouletteInterval=setInterval(()=>{
    const r=active[Math.floor(Math.random()*active.length)];
    se.textContent=r.emoji;sn.textContent=r.name;count++;
    if(count>=maxCount){
      clearInterval(rouletteInterval);
      se.style.animation="none";
      const final=active[Math.floor(Math.random()*active.length)];
      currentResultMenu=final;
      se.textContent=final.emoji;
      sn.style.cssText="font-family:'Black Han Sans',sans-serif;font-size:1.3rem;color:#ff9de2;";
      sn.textContent=final.name+"!";
      // show eat button area below roulette
      document.getElementById("result-area").style.display="block";
      document.getElementById("res-emoji").textContent=final.emoji;
      document.getElementById("res-name").textContent=final.name;
      document.getElementById("res-desc").textContent=final.desc;
      document.getElementById("res-tags").innerHTML=final.tags.map(t=>`<span class="tag">#${t}</span>`).join("");
      document.getElementById("res-runner-up").innerHTML='';
      const eb=document.getElementById('eat-btn');
      eb.textContent='🍽️ 이걸로 먹을래!';eb.classList.remove('eaten');eb.disabled=false;
      document.getElementById('tip-text').textContent='맛있게 드세요 🌙';
    }
  },100);
}

// INIT
loadState();
showQuestion(0);
document.getElementById('random-btn').style.display=settings.showRandomBtn?'block':'none';
</script>
