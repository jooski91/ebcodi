
<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>🌙 야식 추천 게임</title>
<link href="https://fonts.googleapis.com/css2?family=Black+Han+Sans&family=Nanum+Gothic:wght@400;700;800&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: 'Nanum Gothic', sans-serif; background: #0a0a14; color: #f0eaff; min-height: 100vh; overflow-x: hidden; }

.stars { position: fixed; inset: 0; pointer-events: none; z-index: 0;
  background: radial-gradient(ellipse at 20% 30%, rgba(80,40,120,0.15) 0%, transparent 60%),
              radial-gradient(ellipse at 80% 70%, rgba(20,60,100,0.15) 0%, transparent 60%); }
.stars::before { content: ''; position: absolute; inset: 0;
  background-image:
    radial-gradient(1px 1px at 10% 15%,rgba(255,255,255,.6) 0%,transparent 100%),
    radial-gradient(1px 1px at 30% 45%,rgba(255,255,255,.4) 0%,transparent 100%),
    radial-gradient(1px 1px at 55% 20%,rgba(255,255,255,.7) 0%,transparent 100%),
    radial-gradient(1px 1px at 75% 60%,rgba(255,255,255,.3) 0%,transparent 100%),
    radial-gradient(1px 1px at 90% 10%,rgba(255,255,255,.5) 0%,transparent 100%),
    radial-gradient(1px 1px at 45% 80%,rgba(255,255,255,.4) 0%,transparent 100%),
    radial-gradient(1px 1px at 15% 70%,rgba(255,255,255,.6) 0%,transparent 100%),
    radial-gradient(1px 1px at 65% 40%,rgba(255,255,255,.3) 0%,transparent 100%),
    radial-gradient(1px 1px at 85% 85%,rgba(255,255,255,.5) 0%,transparent 100%),
    radial-gradient(1px 1px at 40%  5%,rgba(255,255,255,.6) 0%,transparent 100%),
    radial-gradient(1px 1px at 95% 40%,rgba(255,255,255,.4) 0%,transparent 100%); }

/* NAV */
.nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  display: flex; justify-content: center; padding: 1rem 1.5rem;
  background: linear-gradient(to bottom, rgba(10,10,20,.92), transparent);
  backdrop-filter: blur(6px); }
.nav-inner { display: flex; gap: 4px; background: rgba(255,255,255,.06);
  border: 1px solid rgba(255,255,255,.1); border-radius: 40px; padding: 5px; }
.nav-btn { background: transparent; border: none; border-radius: 30px;
  padding: 7px 16px; color: rgba(240,234,255,.5); font-family: 'Nanum Gothic', sans-serif;
  font-size: .83rem; font-weight: 700; cursor: pointer; transition: all .2s; white-space: nowrap; }
.nav-btn.active { background: rgba(255,157,226,.18); color: #ff9de2; }
.nav-btn:hover:not(.active) { color: rgba(240,234,255,.85); }

/* PAGES */
.page { display: none; position: relative; z-index: 1; }
.page.active { display: block; }

/* GAME */
.container { max-width: 560px; margin: 0 auto; padding: 5.5rem 1.5rem 2rem;
  min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; }
h1 { font-family: 'Black Han Sans', sans-serif; font-size: 2.4rem; text-align: center;
  margin-bottom: .3rem; background: linear-gradient(135deg,#ff9de2,#ffce85,#85e0ff);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.subtitle { text-align: center; font-size: .9rem; color: rgba(240,234,255,.5); margin-bottom: 2.5rem; }
.card { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.1);
  border-radius: 20px; padding: 2rem; width: 100%; backdrop-filter: blur(10px); }

/* QUIZ */
.progress-bar { display: flex; gap: 6px; margin-bottom: 1.5rem; justify-content: center; }
.progress-dot { width: 28px; height: 6px; border-radius: 3px; background: rgba(255,255,255,.12); transition: background .3s; }
.progress-dot.done { background: #ff9de2; }
.progress-dot.active { background: rgba(255,157,226,.5); animation: pulse-dot 1s ease-in-out infinite; }
@keyframes pulse-dot { 0%,100%{opacity:.5} 50%{opacity:1} }
.question-area { text-align: center; margin-bottom: 1.8rem; }
.q-label { font-size: .75rem; color: rgba(240,234,255,.4); letter-spacing: .1em; margin-bottom: .5rem; }
.q-text { font-family: 'Black Han Sans', sans-serif; font-size: 1.35rem; line-height: 1.4; color: #f0eaff; }
.q-emoji { font-size: 2.5rem; margin-bottom: .6rem; display: block; }
.options { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
.opt-btn { background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.12);
  border-radius: 14px; padding: 1rem .8rem; color: #f0eaff;
  font-family: 'Nanum Gothic', sans-serif; font-size: .95rem; font-weight: 700;
  cursor: pointer; transition: all .18s; text-align: center; line-height: 1.3; }
.opt-btn:hover { background: rgba(255,157,226,.15); border-color: rgba(255,157,226,.4); transform: translateY(-2px); }
.opt-btn:active { transform: scale(.97); }
.opt-btn .opt-emoji { display: block; font-size: 1.5rem; margin-bottom: 4px; }

/* RESULT */
.result-area { display: none; text-align: center; animation: fadeIn .5s ease; }
@keyframes fadeIn { from{opacity:0;transform:translateY(10px)} to{opacity:1;transform:translateY(0)} }
.result-emoji { font-size: 5rem; margin-bottom: .5rem; display: block; animation: bounce .6s ease; }
@keyframes bounce { 0%{transform:scale(0)} 60%{transform:scale(1.2)} 100%{transform:scale(1)} }
.result-name { font-family: 'Black Han Sans', sans-serif; font-size: 2rem;
  background: linear-gradient(135deg,#ff9de2,#ffce85);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; margin-bottom: .4rem; }
.result-desc { font-size: .9rem; color: rgba(240,234,255,.65); line-height: 1.6; margin-bottom: 1.2rem; }
.result-tags { display: flex; flex-wrap: wrap; gap: 6px; justify-content: center; margin-bottom: 1.2rem; }
.tag { background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.15);
  border-radius: 20px; padding: 4px 12px; font-size: .78rem; color: rgba(240,234,255,.7); }
.result-runner-up { margin-bottom: 1.2rem; }
.runner-label { font-size: .75rem; color: rgba(240,234,255,.35); margin-bottom: 8px; }
.runner-items { display: flex; gap: 8px; justify-content: center; flex-wrap: wrap; }
.runner-item { background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.1);
  border-radius: 12px; padding: 6px 12px; font-size: .82rem; color: rgba(240,234,255,.55); }

/* EAT BUTTON */
.eat-btn { width: 100%; background: linear-gradient(135deg,#ff9de2,#ffce85); border: none;
  border-radius: 16px; padding: 1.1rem 2rem; font-family: 'Black Han Sans', sans-serif;
  font-size: 1.2rem; color: #1a0a2e; cursor: pointer; transition: all .2s; margin-bottom: 10px;
  letter-spacing: .02em; display: flex; align-items: center; justify-content: center; gap: 8px; }
.eat-btn:hover { transform: translateY(-2px) scale(1.02); filter: brightness(1.06); }
.eat-btn:active { transform: scale(.98); }
.eat-btn.eaten { background: linear-gradient(135deg,#7be8a0,#5bcfdc); animation: eatPop .4s ease; }
@keyframes eatPop { 0%{transform:scale(1)} 40%{transform:scale(1.08)} 100%{transform:scale(1)} }

.restart-btn { width: 100%; background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.12);
  border-radius: 14px; padding: .85rem 2rem; font-family: 'Black Han Sans', sans-serif;
  font-size: 1rem; color: rgba(240,234,255,.6); cursor: pointer; transition: all .2s; }
.restart-btn:hover { background: rgba(255,255,255,.1); color: #f0eaff; }
.tip-text { margin-top: 1rem; font-size: .78rem; color: rgba(240,234,255,.25); text-align: center; }

/* ROULETTE */
.roulette-wrap { display: none; text-align: center; padding: 1rem 0; animation: fadeIn .4s ease; }
.roulette-title { font-family: 'Black Han Sans', sans-serif; font-size: 1rem; color: rgba(240,234,255,.5); margin-bottom: 1rem; }
.spin-ring { width: 100px; height: 100px; border-radius: 50%;
  border: 3px solid rgba(255,157,226,.3); border-top-color: #ff9de2;
  margin: 0 auto .8rem; display: flex; align-items: center; justify-content: center;
  animation: spin .4s linear infinite; font-size: 2.5rem; }
@keyframes spin { to { transform: rotate(360deg); } }
.roulette-name { font-family: 'Black Han Sans', sans-serif; font-size: 1.1rem; color: rgba(240,234,255,.7); }
.separator { display: flex; align-items: center; gap: 10px; margin: 1.5rem 0; }
.sep-line { flex: 1; height: 1px; background: rgba(255,255,255,.08); }
.sep-text { font-size: .75rem; color: rgba(240,234,255,.3); }
.random-btn { width: 100%; background: rgba(255,255,255,.04);
  border: 1px dashed rgba(255,255,255,.2); border-radius: 14px; padding: .8rem;
  color: rgba(240,234,255,.5); font-family: 'Nanum Gothic', sans-serif; font-size: .85rem;
  cursor: pointer; transition: all .2s; }
.random-btn:hover { border-color: rgba(255,206,133,.4); color: #ffce85; background: rgba(255,206,133,.05); }

/* ===================== HISTORY PAGE ===================== */
.history-wrap { max-width: 720px; margin: 0 auto; padding: 5.5rem 1.5rem 3rem; }
.history-top { display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 1.8rem; flex-wrap: wrap; gap: 12px; }
.history-title-group {}
.history-title { font-family: 'Black Han Sans', sans-serif; font-size: 1.8rem; color: #f0eaff; line-height: 1.1; }
.history-subtitle { font-size: .82rem; color: rgba(240,234,255,.38); margin-top: 4px; }
.history-stats { display: flex; gap: 10px; }
.hstat { background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.08); border-radius: 12px;
  padding: 8px 14px; text-align: center; }
.hstat-num { font-family: 'Black Han Sans', sans-serif; font-size: 1.3rem; color: #ff9de2; line-height: 1; }
.hstat-label { font-size: .7rem; color: rgba(240,234,255,.38); margin-top: 3px; }

/* TIMELINE */
.timeline { position: relative; padding-left: 0; }

.tl-month-header { display: flex; align-items: center; gap: 12px; margin: 2rem 0 1rem; }
.tl-month-line { flex: 1; height: 1px; background: rgba(255,255,255,.07); }
.tl-month-label { font-family: 'Black Han Sans', sans-serif; font-size: .85rem;
  color: rgba(240,234,255,.35); letter-spacing: .06em; white-space: nowrap; }

.tl-day-group { margin-bottom: 6px; }
.tl-day-header { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; cursor: pointer; }
.tl-day-dot { width: 10px; height: 10px; border-radius: 50%; background: rgba(255,157,226,.35);
  flex-shrink: 0; transition: background .2s; }
.tl-day-group:hover .tl-day-dot { background: #ff9de2; }
.tl-day-label { font-size: .8rem; color: rgba(240,234,255,.4); font-weight: 700; }
.tl-day-count { font-size: .72rem; background: rgba(255,255,255,.07); border-radius: 20px;
  padding: 2px 8px; color: rgba(240,234,255,.35); }
.tl-connector { flex: 1; height: 1px; background: rgba(255,255,255,.05); }

.tl-entries { display: flex; flex-direction: column; gap: 8px; padding-left: 20px;
  border-left: 1px solid rgba(255,255,255,.06); margin-left: 4px; padding-bottom: 12px; }

.tl-entry { display: flex; align-items: center; gap: 12px;
  background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.07);
  border-radius: 14px; padding: 12px 16px; transition: all .15s; position: relative; }
.tl-entry:hover { background: rgba(255,255,255,.07); border-color: rgba(255,255,255,.12); }
.tl-entry-emoji { font-size: 1.8rem; flex-shrink: 0; width: 40px; text-align: center; }
.tl-entry-body { flex: 1; min-width: 0; }
.tl-entry-name { font-family: 'Black Han Sans', sans-serif; font-size: 1rem; color: #f0eaff; }
.tl-entry-time { font-size: .72rem; color: rgba(240,234,255,.35); margin-top: 2px; }
.tl-entry-note { font-size: .78rem; color: rgba(240,234,255,.5); margin-top: 4px;
  font-style: italic; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.tl-entry-right { display: flex; flex-direction: column; align-items: flex-end; gap: 4px; flex-shrink: 0; }
.tl-entry-score { font-size: .7rem; color: rgba(240,234,255,.3); }
.tl-del-btn { background: transparent; border: 1px solid rgba(255,80,80,.18);
  border-radius: 7px; width: 26px; height: 26px; display: flex; align-items: center; justify-content: center;
  color: rgba(255,100,100,.4); cursor: pointer; font-size: .85rem; transition: all .15s; }
.tl-del-btn:hover { background: rgba(255,80,80,.1); border-color: rgba(255,100,100,.5); color: #ff6464; }

/* EMPTY STATE */
.history-empty { text-align: center; padding: 4rem 2rem; }
.history-empty-emoji { font-size: 4rem; display: block; margin-bottom: 1rem; opacity: .4; }
.history-empty-text { font-family: 'Black Han Sans', sans-serif; font-size: 1.1rem; color: rgba(240,234,255,.3); margin-bottom: .5rem; }
.history-empty-hint { font-size: .82rem; color: rgba(240,234,255,.2); }

/* HEAT CHART */
.heat-section { margin-bottom: 2rem; }
.heat-title { font-size: .78rem; color: rgba(240,234,255,.35); margin-bottom: .8rem; letter-spacing: .06em; }
.heat-chart { display: flex; gap: 4px; flex-wrap: wrap; }
.heat-cell { width: 14px; height: 14px; border-radius: 3px; background: rgba(255,255,255,.06); transition: all .2s; }
.heat-cell.h1 { background: rgba(255,157,226,.25); }
.heat-cell.h2 { background: rgba(255,157,226,.5); }
.heat-cell.h3 { background: rgba(255,157,226,.8); }
.heat-cell:hover { transform: scale(1.3); }

/* FAVORITE */
.fav-section { margin-bottom: 2rem; }
.fav-title { font-size: .78rem; color: rgba(240,234,255,.35); margin-bottom: .8rem; letter-spacing: .06em; }
.fav-list { display: flex; gap: 8px; flex-wrap: wrap; }
.fav-chip { display: flex; align-items: center; gap: 6px; background: rgba(255,255,255,.06);
  border: 1px solid rgba(255,255,255,.1); border-radius: 30px; padding: 6px 14px; }
.fav-chip-emoji { font-size: 1.1rem; }
.fav-chip-name { font-size: .82rem; font-weight: 700; color: rgba(240,234,255,.7); }
.fav-chip-cnt { font-size: .72rem; color: rgba(240,234,255,.35); }
.fav-chip.rank1 { border-color: rgba(255,206,133,.4); background: rgba(255,206,133,.08); }
.fav-chip.rank1 .fav-chip-name { color: #ffce85; }

/* NOTE MODAL */
.modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,.6); z-index: 500;
  display: none; align-items: center; justify-content: center; padding: 1.5rem; }
.modal-overlay.open { display: flex; }
.modal-box { background: #14102a; border: 1px solid rgba(255,255,255,.12);
  border-radius: 20px; padding: 1.8rem; width: 100%; max-width: 400px; animation: fadeIn .25s ease; }
.modal-title { font-family: 'Black Han Sans', sans-serif; font-size: 1.2rem; color: #f0eaff; margin-bottom: .4rem; }
.modal-sub { font-size: .82rem; color: rgba(240,234,255,.4); margin-bottom: 1.2rem; }
.modal-input { width: 100%; background: rgba(255,255,255,.07); border: 1px solid rgba(255,255,255,.12);
  border-radius: 12px; padding: 10px 14px; color: #f0eaff; font-family: 'Nanum Gothic', sans-serif;
  font-size: .9rem; outline: none; resize: none; margin-bottom: 1rem; }
.modal-input:focus { border-color: rgba(255,157,226,.4); }
.modal-btns { display: flex; gap: 8px; }
.modal-ok { flex: 1; background: linear-gradient(135deg,#ff9de2,#ffce85); border: none;
  border-radius: 12px; padding: .8rem; font-family: 'Black Han Sans', sans-serif;
  font-size: 1rem; color: #1a0a2e; cursor: pointer; }
.modal-cancel { flex: 1; background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1);
  border-radius: 12px; padding: .8rem; font-family: 'Black Han Sans', sans-serif;
  font-size: 1rem; color: rgba(240,234,255,.5); cursor: pointer; }

/* SETTINGS */
.settings-container { max-width: 600px; margin: 0 auto; padding: 5.5rem 1.5rem 3rem; }
.settings-title { font-family: 'Black Han Sans', sans-serif; font-size: 1.6rem; margin-bottom: .3rem; color: #f0eaff; }
.settings-subtitle { font-size: .85rem; color: rgba(240,234,255,.4); margin-bottom: 2rem; }
.section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem; }
.section-title { font-family: 'Black Han Sans', sans-serif; font-size: 1rem; color: rgba(240,234,255,.7); }
.section-desc { font-size: .78rem; color: rgba(240,234,255,.35); margin-top: 2px; }
.settings-card { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.09);
  border-radius: 18px; padding: 1.4rem 1.6rem; margin-bottom: 1.2rem; }
.setting-row { display: flex; align-items: center; justify-content: space-between;
  padding: .7rem 0; border-bottom: 1px solid rgba(255,255,255,.06); }
.setting-row:last-child { border-bottom: none; padding-bottom: 0; }
.setting-row:first-child { padding-top: 0; }
.setting-info { flex: 1; }
.setting-label { font-size: .9rem; font-weight: 700; color: #f0eaff; margin-bottom: 2px; }
.setting-hint { font-size: .75rem; color: rgba(240,234,255,.38); }
.toggle { position: relative; width: 44px; height: 24px; flex-shrink: 0; }
.toggle input { opacity: 0; width: 0; height: 0; }
.toggle-slider { position: absolute; inset: 0; background: rgba(255,255,255,.12); border-radius: 24px; cursor: pointer; transition: .25s; }
.toggle-slider::before { content: ''; position: absolute; width: 18px; height: 18px;
  left: 3px; top: 3px; background: rgba(240,234,255,.6); border-radius: 50%; transition: .25s; }
.toggle input:checked + .toggle-slider { background: rgba(255,157,226,.35); }
.toggle input:checked + .toggle-slider::before { transform: translateX(20px); background: #ff9de2; }
.menu-list { display: flex; flex-direction: column; gap: 8px; margin-bottom: 1rem; }
.menu-item { display: flex; align-items: center; gap: 10px; background: rgba(255,255,255,.04);
  border: 1px solid rgba(255,255,255,.08); border-radius: 12px; padding: 10px 14px; }
.menu-item.disabled { opacity: .4; }
.menu-emoji-badge { font-size: 1.4rem; width: 36px; text-align: center; flex-shrink: 0; }
.menu-info { flex: 1; min-width: 0; }
.menu-item-name { font-size: .9rem; font-weight: 700; color: #f0eaff; }
.menu-item-tags { font-size: .72rem; color: rgba(240,234,255,.35); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-top: 2px; }
.menu-actions { display: flex; align-items: center; gap: 6px; flex-shrink: 0; }
.menu-toggle-btn { background: rgba(255,255,255,.07); border: 1px solid rgba(255,255,255,.12);
  border-radius: 8px; padding: 4px 10px; font-size: .72rem; color: rgba(240,234,255,.55); cursor: pointer; transition: all .15s; }
.menu-toggle-btn.on { background: rgba(255,157,226,.12); border-color: rgba(255,157,226,.3); color: #ff9de2; }
.menu-delete-btn { background: transparent; border: 1px solid rgba(255,80,80,.2); border-radius: 8px;
  width: 28px; height: 28px; display: flex; align-items: center; justify-content: center;
  color: rgba(255,100,100,.5); cursor: pointer; font-size: .9rem; transition: all .15s; }
.menu-delete-btn:hover { background: rgba(255,80,80,.1); border-color: rgba(255,100,100,.5); color: #ff6464; }
.add-menu-form { background: rgba(255,255,255,.03); border: 1px dashed rgba(255,255,255,.15);
  border-radius: 14px; padding: 1.2rem; margin-top: .5rem; }
.add-form-title { font-size: .82rem; font-weight: 700; color: rgba(240,234,255,.5); margin-bottom: 1rem; }
.form-row { display: flex; gap: 8px; margin-bottom: 10px; flex-wrap: wrap; }
.form-input { flex: 1; min-width: 80px; background: rgba(255,255,255,.07); border: 1px solid rgba(255,255,255,.12);
  border-radius: 10px; padding: 9px 12px; color: #f0eaff; font-family: 'Nanum Gothic', sans-serif;
  font-size: .88rem; outline: none; transition: border .2s; }
.form-input::placeholder { color: rgba(240,234,255,.25); }
.form-input:focus { border-color: rgba(255,157,226,.4); }
.form-input.emoji-input { width: 64px; min-width: 64px; flex: none; text-align: center; font-size: 1.2rem; }
.form-input.full { width: 100%; flex: none; }
.add-btn { background: linear-gradient(135deg,rgba(255,157,226,.2),rgba(255,206,133,.2));
  border: 1px solid rgba(255,157,226,.3); border-radius: 10px; padding: 9px 18px;
  color: #ff9de2; font-family: 'Nanum Gothic', sans-serif; font-size: .88rem; font-weight: 700;
  cursor: pointer; transition: all .18s; white-space: nowrap; }
.add-btn:hover { transform: translateY(-1px); }
.mood-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 8px; }
.mood-opt { display: flex; align-items: center; gap: 8px; background: rgba(255,255,255,.04);
  border: 1px solid rgba(255,255,255,.09); border-radius: 12px; padding: 10px 12px; cursor: pointer; transition: all .15s; }
.mood-opt.selected { background: rgba(255,157,226,.1); border-color: rgba(255,157,226,.35); }
.mood-opt-emoji { font-size: 1.2rem; }
.mood-opt-label { font-size: .85rem; font-weight: 700; color: rgba(240,234,255,.65); }
.mood-opt.selected .mood-opt-label { color: #ff9de2; }
.save-bar { position: fixed; bottom: 1.5rem; left: 50%; transform: translateX(-50%);
  background: rgba(20,15,35,.95); border: 1px solid rgba(255,255,255,.12); border-radius: 16px;
  padding: .8rem 1.2rem; display: flex; align-items: center; gap: 12px;
  backdrop-filter: blur(12px); z-index: 200; opacity: 0; pointer-events: none; transition: opacity .2s; }
.save-bar.visible { opacity: 1; pointer-events: auto; }
.save-bar-text { font-size: .82rem; color: rgba(240,234,255,.55); }
.save-bar-btn { background: linear-gradient(135deg,#ff9de2,#ffce85); border: none; border-radius: 10px;
  padding: 7px 18px; font-family: 'Black Han Sans', sans-serif; font-size: .88rem; color: #1a0a2e; cursor: pointer; }
.count-badge { background: rgba(255,157,226,.15); border-radius: 20px; padding: 3px 10px;
